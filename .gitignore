# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# 运行期 client 写出的 trace 日志（本地/mock 跑出的噪声不入库；保留目录占位）
# 交付件（client/）在平台运行时也写这里，随包下载后再复制到根目录 logs/ 提交分析。
client/logs/*.log
!client/logs/.gitkeep

# 采集回的对局 trace（logs/）：仅内网采集与分析，**不入库不上传**（原始大体量数据，仅内网可见）。
# 仓库只保留 logs/ 的目录骨架（.gitkeep + README）。
# 分析产物 reports/ 入库上传——内网跑 analysis 生成后 commit/push，外部 Claude Code pull 读取。
logs/**/*.log

# sim 回归门产物（ephemeral：镜像自博弈 A/B，仅本地验回归用，不入库）
reports/sim_*/

# §3 A/B 输出目录的可再生单局 report.json（由源 trace 目录重生成，不入库；仅提交聚合 md + index）
reports/iter36_ab_out/*.report.json

# 本地 IDE / 工具设置
.claude/
.idea/
.vscode/
.DS_Store
